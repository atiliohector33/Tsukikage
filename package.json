{
  "name": "tsukikage",
  "version": "0.1.3",
  "description": "🏆 A sleek, customizable React ranking component library",
  "author": "your-name",
  "license": "MIT",
  "keywords": [
    "react",
    "ranking",
    "leaderboard",
    "component",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/tsukikage"
  },
  "homepage": "https://github.com/your-username/tsukikage#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/tsukikage.umd.cjs",
  "module": "./dist/tsukikage.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tsukikage.js",
      "require": "./dist/tsukikage.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
